#!/usr/bin/env bash
# plugable-microscope — live preview of a Plugable USB microscope.
#
# Controls (inside the viewer window):
#   SPACE          take a screenshot       → $PMS_CAPTURES/Pictures
#   Ctrl+SPACE     toggle video recording  → $PMS_CAPTURES/Videos
#   click "SNAP"   take a screenshot
#
# Env vars:
#   PMS_VIEWER     viewer binary (default: mpv)
#   PMS_CAPTURES   capture root dir (default: <repo>/Captures, set by setup.sh)
set -euo pipefail

VIEWER="${PMS_VIEWER:-mpv}"

# setup.sh prepends an `export PMS_REPO_ROOT=/abs/path` line above this one
# in the installed copy, so the value survives execution from any cwd. When
# run straight from the repo (no install), we self-resolve from our own path.
SELF="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
PMS_REPO_ROOT="${PMS_REPO_ROOT:-$(cd "$(dirname "$SELF")/.." 2>/dev/null && pwd)}"

LUA_SCRIPT="${PMS_LUA:-$PMS_REPO_ROOT/share/plugable-microscope.lua}"
export PMS_CAPTURES="${PMS_CAPTURES:-$PMS_REPO_ROOT/Captures}"

err() { printf 'plugable-microscope: %s\n' "$*" >&2; }

require() {
    command -v "$1" >/dev/null 2>&1 || { err "missing dependency: $1 (re-run setup.sh)"; exit 1; }
}

find_linux_device() {
    shopt -s nullglob
    local pat dev
    for pat in \
        '/dev/v4l/by-id/usb-Etron_Technology*USB_Microscope-video-index0' \
        '/dev/v4l/by-id/*Plugable*-video-index0' \
        '/dev/v4l/by-id/*Microscope*-video-index0' \
        '/dev/v4l/by-id/*microscope*-video-index0' \
        '/dev/v4l/by-id/*Etron*-video-index0'; do
        for dev in $pat; do
            [ -e "$dev" ] && { readlink -f "$dev"; return 0; }
        done
    done
    local entry name
    for entry in /sys/class/video4linux/*; do
        [ -r "$entry/name" ] || continue
        name=$(cat "$entry/name")
        case "$name" in
            *[Mm]icroscope*|*Etron*) echo "/dev/$(basename "$entry")"; return 0 ;;
        esac
    done
    return 1
}

find_mac_index() {
    require ffmpeg
    ffmpeg -hide_banner -f avfoundation -list_devices true -i "" 2>&1 | awk '
        /AVFoundation video devices/ { vid = 1; next }
        /AVFoundation audio devices/ { vid = 0 }
        vid {
            if (match($0, /\[[0-9]+\]/)) {
                idx = substr($0, RSTART + 1, RLENGTH - 2)
                rest = substr($0, RSTART + RLENGTH)
                if (tolower(rest) ~ /microscope|etron/) { print idx; exit }
            }
        }
    '
}

mpv_args=( --profile=low-latency --title="Plugable Microscope" --force-window=yes )
[ -f "$LUA_SCRIPT" ] && mpv_args+=( "--script=$LUA_SCRIPT" )

case "$(uname -s)" in
    Linux)
        require "$VIEWER"
        DEV=$(find_linux_device) || { err "Plugable Microscope not found. Plug it in and try again."; exit 1; }
        exec "$VIEWER" "av://v4l2:$DEV" "${mpv_args[@]}" "$@"
        ;;
    Darwin)
        require "$VIEWER"
        IDX=$(find_mac_index)
        [ -n "$IDX" ] || { err "Plugable Microscope not found. Plug it in and try again."; exit 1; }
        exec "$VIEWER" "av://avfoundation:$IDX" "${mpv_args[@]}" "$@"
        ;;
    *)
        err "unsupported OS: $(uname -s) — use plugable-microscope.ps1 on Windows"
        exit 1
        ;;
esac
