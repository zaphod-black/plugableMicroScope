# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*~

# Build artefacts
build/
dist/

# Captured media — ignore everything under Captures/, but keep the
# Pictures/ and Videos/ subdirectories tracked via their .gitkeep files.
Captures/**
!Captures/Pictures/
!Captures/Videos/
!Captures/Pictures/.gitkeep
!Captures/Videos/.gitkeep

# Local secrets / overrides
.env
.env.local
*.local
